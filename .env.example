# Albion Analytics Bot — Environment Variables Example
DISCORD_TOKEN=your_bot_token_here
DATABASE_URL=postgresql://user:password@host:port/database_name
GUILD_ID=your_guild_id_here
TICKETS_CATEGORY_ID=your_tickets_category_id_here
# Optional economy/regear ticket categories:
# global fallback category for /economy regear-ticket
REGEAR_TICKETS_CATEGORY_ID=
# per-server mapping (guild_id:category_id,guild_id2:category_id2)
REGEAR_TICKETS_CATEGORY_IDS=
# Optional additional economy roles from env:
ACCOUNTANT_ROLE_ID=
RECONCILER_ROLE_ID=
# Or comma-separated list of extra economy role IDs
ECONOMY_ROLE_IDS=
PYTHONUNBUFFERED=1

# Web dashboard (same Render Web Service as the bot)
# Open https://your-service.onrender.com/dashboard after deploy
DASHBOARD_SECRET=choose_a_long_random_token
# Optional; defaults to DASHBOARD_SECRET if unset
FLASK_SECRET_KEY=

# Neon (etc.) storage cap for dashboard System tab (bytes). Default ~0.5 GiB.
# DASHBOARD_DB_QUOTA_BYTES=536870912

# Optional: override path to event roster templates (default: ./events_templates.txt next to bot.py).
# EVENT_TEMPLATES_PATH=/path/to/events_templates.txt

# Dashboard “Load names from Discord”: cache GET /guilds/{id}/roles (seconds). Reduces 429 global rate limits.
# DISCORD_ROLES_CACHE_SECONDS=120
# DISCORD_ROLES_MAX_RETRIES=5
# DISCORD_ROLES_RETRY_CAP_SEC=60